# ── ZoyZoy Hub — Environment Variables ──────────────────
# Copy this file to .env and fill in your values

# Anthropic API Key (get from console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-YOUR_KEY_HERE

# JWT Secret (generate a random string)
JWT_SECRET=change_me_to_something_random_and_long

# Replicate API token (optional paid fallback only — local open-source engine is default)
# REPLICATE_API_TOKEN=r8_YOUR_TOKEN_HERE

# Face swap engine (free open-source InsightFace runs in the face-swap Docker service)
# FACE_SWAP_URL=http://face-swap:8080
# FACE_SWAP_PROVIDER=local

# Database (auto-configured for Docker — only change for external DB)
DATABASE_URL=postgresql://zoyzoy:zoyzoy_secret@db:5432/zoyzoy_hub

# Contact form email (optional — inquiries always save in admin Messages tab)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=your@gmail.com
# SMTP_PASS=your_app_password
# SMTP_FROM="ibtihajForage <your@gmail.com>"
# INQUIRY_NOTIFY_EMAIL=hello@yourdomain.com
