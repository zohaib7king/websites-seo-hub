# SSH connection to your dev server
SSH_HOST=your-server-ip
SSH_PORT=22
SSH_USER=root
SSH_PASSWORD=your-password

# ZoyZoy Hub is a single git repo (docker-compose.yml at the root)
REPO_URL=https://github.com/zohaib7king/websites-seo-hub.git
REPO_PATH=/root/zoyzoy/websites-seo-hub
GIT_BRANCH=main

# Where docker-compose.yml lives (defaults to REPO_PATH = repo root)
COMPOSE_PATH=/root/zoyzoy/websites-seo-hub

# Docker compose command to run after pull
DEPLOY_COMMAND=docker compose up -d --build

# Postgres service/db inside the compose stack (used for migrations)
DB_SERVICE=db
DB_USER=zoyzoy
DB_NAME=zoyzoy_hub
MIGRATIONS_DIR=api/src/db/migrations

# ── Remote HTTP mode (for a hosted https connector) ──
# Set MCP_TRANSPORT=http (or any PORT) to run as an HTTP server instead of stdio.
MCP_TRANSPORT=http
PORT=8787
# Auth — either gate is sufficient. Generate strong random values!
#   path:   https://<your-domain>/<MCP_PATH_SECRET>/mcp
#   bearer: Authorization: Bearer <MCP_AUTH_TOKEN>
MCP_PATH_SECRET=change-me-long-random
MCP_AUTH_TOKEN=change-me-long-random
